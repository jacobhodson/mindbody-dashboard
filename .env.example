# Copy this to .env and fill in your values
# In Netlify: set these under Site Settings → Environment Variables

# From your Mindbody Developer Portal (https://developers.mindbodyonline.com)
MINDBODY_API_KEY=your_api_key_here

# Your Mindbody site/studio ID (negative IDs are sandbox; positive = production)
MINDBODY_SITE_ID=-99

# Staff account credentials (used to generate a token for accessing client PII)
# Create a dedicated staff account with read-only access for security
MINDBODY_USERNAME=your_staff_username
MINDBODY_PASSWORD=your_staff_password
